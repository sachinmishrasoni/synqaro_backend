        {
          "name": "login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();\r",
                  "\r",
                  "if (res.data) {\r",
                  "    pm.environment.set(\"accessToken\", res.data.accessToken);\r",
                  "    pm.environment.set(\"refreshToken\", res.data.refreshToken);\r",
                  "\r",
                  "    if (res.data.user?.id) {\r",
                  "        pm.environment.set(\"userId\", res.data.user.id);\r",
                  "    }\r",
                  "\r",
                  "    console.log(\"Token and user ID set successfully.\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
